import { Button, ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "pdfiuh";
    icon: @image-url("../../../assets/logo.png");
    preferred-width: 800px;
    preferred-height: 600px;

    callback open-file();
    callback zoom-in();
    callback zoom-out();

    in-out property <float> zoom-level: 1.0;
    in-out property <string> current-file: "";
    in property <image> pdf-page-image;

    VerticalBox {
        // Toolbar
        HorizontalBox {
            height: 40px;
            padding: 8px;
            spacing: 8px;

            Button {
                text: "Open";
                clicked => { open-file(); }
            }

            Rectangle { width: 1px; background: #ccc; }

            Button {
                text: "+";
                clicked => { zoom-in(); }
            }

            Text {
                text: "Zoom: " + round(zoom-level * 100) + "%";
                vertical-alignment: center;
            }

            Button {
                text: "-";
                clicked => { zoom-out(); }
            }
        }

        // Document viewport
        ScrollView {
            viewport-width: 800px * zoom-level;
            viewport-height: 1000px * zoom-level;

            // Placeholder for PDF rendering
            Rectangle {
                background: white;
                width: 595px * zoom-level;  // A4 width in pixels
                height: 842px * zoom-level;  // A4 height

                Image {
                    source: root.pdf-page-image;
                    width: 100%;
                    height: 100%;
                    image-fit: contain;
                }

                if (current-file == "") : Text {
                    text: "No document loaded";
                    color: #666;
                }
            }
        }
    }
}
